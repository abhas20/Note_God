generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
  // output = "./generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Notes {
  id    String     @id @default(uuid())
  note  String
  author User @relation(fields: [authId], references: [id])
  authId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
}

model User {
  id       String     @id @default(uuid())
  email    String  @unique
  imgUrl   String?
  Notes Notes[]
  Messages Messages[]
  quizzes Quiz[]
  attempts Attempt[]
  FileUploads FileUploads[]
}

model Messages{
  id        String   @id @default(uuid())
  content   String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())  
}


model FileUploads {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  uploader  User     @relation(fields: [uploaderId], references: [id])
  uploaderId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Quiz {
  id        String   @id @default(uuid())
  authId     String
  author    User     @relation(fields: [authId], references: [id], onDelete: Cascade)
  title     String
  questions Question[]
  createdAt DateTime @default(now())
  attempts  Attempt[]
}

model Question {
  id        String   @id @default(uuid())
  quizId    String
  questionText String
  options   String[]
  correctAnswerIndex Int
  correctAnswer String
  Explanation String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Attempt {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  score     Int
  total     Int
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}